---
import Socials from "./Socials.astro"
import Project from "./Project.astro"
import BlogCard from "./BlogCard.astro"
import CourseworkListItem from "./CourseworkListItem.astro"
import { getCollection } from "astro:content"

let allProjects = await getCollection("projects")
allProjects = allProjects.sort((a, b) => {
  if (a.data.date > b.data.date) return -1
  if (a.data.date < b.data.date) return 1
  if (a.data.name < b.data.name) return -1
  if (a.data.name > b.data.name) return 1
  return 0
})

let allBlogPosts = await getCollection("blog")
allBlogPosts = allBlogPosts.sort((a, b) => {
  if (a.data.date > b.data.date) return -1
  if (a.data.date < b.data.date) return 1
  return a.data.title.localeCompare(b.data.title)
})

let allCourses = await getCollection("coursework")
allCourses = allCourses.sort((a, b) => {
  if (a.data.date > b.data.date) return -1
  if (a.data.date < b.data.date) return 1
  return a.data.name.localeCompare(b.data.name)
})

const courseworkGroups = new Map<string, typeof allCourses>()
for (const course of allCourses) {
  const groupedCourses = courseworkGroups.get(course.data.quarter) ?? []
  groupedCourses.push(course)
  courseworkGroups.set(course.data.quarter, groupedCourses)
}

const projectTags = Array.from(
  new Set(allProjects.flatMap((entry) => entry.data.tags ?? [])),
).sort((a, b) => a.localeCompare(b))

const blogTags = Array.from(
  new Set(allBlogPosts.flatMap((entry) => entry.data.tags ?? [])),
).sort((a, b) => a.localeCompare(b))

const tabs = [
  { id: "projects", label: "Projects" },
  { id: "blog", label: "Blog" },
  { id: "coursework", label: "Coursework" },
]

const emptyStateClasses =
  "rounded-[24px] bg-white/35 p-6 md:p-8 shadow-border text-(--active-muted)"
---

<header class="px-4 md:px-0 font-triple">
  <Socials />
  <h1
    class="text-7xl lg:text-[6.7rem] weight-normal text-(--active-hue) mt-4"
  >
    Siddhant Maji
  </h1>
  {<!-- prettier-ignore -->}
  <p class="my-6 weight-medium text-xl/8 md:text-[1.45rem] md:leading-9 text-pretty max-w">
    Senior at Independence High School, Frisco, Texas.<br />
  </p>
  <details
    class="group mb-8 rounded-3xl p-2 shadow-border open:shadow-none open:backdrop-saturate-125 open:backdrop-brightness-125 transition-colors grid text-(--active-muted) open:text-(--active-text)"
  >
    <summary
      class="font-sans rounded-3xl transition-colors cursor-pointer pl-1 flex items-center gap-2 font-bold outline-offset-8 group-open:outline-dark overflow-clip"
    >
      <svg
        class="-rotate-45 group-open:rotate-0 transition-transform"
        fill-rule="evenodd"
        clip-rule="evenodd"
        stroke-linejoin="round"
        stroke-miterlimit="1.414"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        viewBox="0 0 32 32"
        preserveAspectRatio="xMidYMid meet"
        fill="currentColor"
        width="24"
        height="24"
      >
        <path
          d="M11.121,9.707c-0.39,-0.391 -1.024,-0.391 -1.414,0c-0.391,0.39 -0.391,1.024 0,1.414l4.95,4.95l-4.95,4.95c-0.391,0.39 -0.391,1.023 0,1.414c0.39,0.39 1.024,0.39 1.414,0l4.95,-4.95l4.95,4.95c0.39,0.39 1.023,0.39 1.414,0c0.39,-0.391 0.39,-1.024 0,-1.414l-4.95,-4.95l4.95,-4.95c0.39,-0.39 0.39,-1.024 0,-1.414c-0.391,-0.391 -1.024,-0.391 -1.414,0l-4.95,4.95l-4.95,-4.95Z"
        >
        </path>
      </svg>
      Full Bio
    </summary>
    <div class="p-2 md:pr-0">
      <p class="text-pretty font-mono-slabs weight-normal text-lg/8 md:text-xl/9 max-w-3xl">
        I’m Siddhant Maji (you can call me Sid!), an incoming freshman at UCSD/Purdue studying Computer Science.
      </p>
    </div>
  </details>
</header>

<section class="mx-4 md:mx-0 mt-12 mb-6">
  <details data-filter-panel="projects" class="group rounded-3xl border border-black/10 bg-white/45 p-3 shadow-border">
    <summary class="flex cursor-pointer list-none items-center justify-between gap-4 rounded-[18px] px-3 py-2 font-sans font-medium text-(--active-text)">
      <span>Filter projects tags</span>
      <span class="text-sm text-(--active-muted)">Choose one or more</span>
    </summary>
    <div class="mt-3 space-y-3 px-1 pb-1">
      <input
        type="search"
        placeholder="Search project tags"
        data-tag-search="projects"
        class="w-full rounded-full border border-black/10 bg-white/80 px-4 py-2 text-base text-(--active-text) outline-none placeholder:text-(--active-muted)"
      />
      <div class="flex flex-wrap gap-2" data-tag-options="projects">
        {projectTags.length ? projectTags.map((tag) => (
          <label data-tag-option data-tag-name={tag} class="inline-flex cursor-pointer items-center">
            <input type="checkbox" value={tag} class="peer sr-only" data-tag-checkbox="projects" />
            <span class="rounded-full border border-black/10 bg-white/70 px-3 py-1 text-sm font-medium text-(--active-muted) shadow-sm transition peer-checked:bg-(--active-hue) peer-checked:text-white">
              {tag}
            </span>
          </label>
        )) : <p class="text-sm text-(--active-muted)">No project tags yet.</p>}
      </div>
    </div>
  </details>

  <details data-filter-panel="blog" hidden class="group mt-4 rounded-3xl border border-black/10 bg-white/45 p-3 shadow-border">
    <summary class="flex cursor-pointer list-none items-center justify-between gap-4 rounded-[18px] px-3 py-2 font-sans font-medium text-(--active-text)">
      <span>Filter blog tags</span>
      <span class="text-sm text-(--active-muted)">Choose one or more</span>
    </summary>
    <div class="mt-3 space-y-3 px-1 pb-1">
      <input
        type="search"
        placeholder="Search blog tags"
        data-tag-search="blog"
        class="w-full rounded-full border border-black/10 bg-white/80 px-4 py-2 text-base text-(--active-text) outline-none placeholder:text-(--active-muted)"
      />
      <div class="flex flex-wrap gap-2" data-tag-options="blog">
        {blogTags.length ? blogTags.map((tag) => (
          <label data-tag-option data-tag-name={tag} class="inline-flex cursor-pointer items-center">
            <input type="checkbox" value={tag} class="peer sr-only" data-tag-checkbox="blog" />
            <span class="rounded-full border border-black/10 bg-white/70 px-3 py-1 text-sm font-medium text-(--active-muted) shadow-sm transition peer-checked:bg-(--active-hue) peer-checked:text-white">
              {tag}
            </span>
          </label>
        )) : <p class="text-sm text-(--active-muted)">No blog tags yet.</p>}
      </div>
    </div>
  </details>

  <details data-filter-panel="coursework" hidden class="group mt-4 rounded-3xl border border-black/10 bg-white/45 p-3 shadow-border">
    <summary class="flex cursor-pointer list-none items-center justify-between gap-4 rounded-[18px] px-3 py-2 font-sans font-medium text-(--active-text)">
      <span>Filter coursework</span>
      <span class="text-sm text-(--active-muted)">Recommended or not</span>
    </summary>
    <div class="mt-3 flex flex-wrap gap-2 px-1 pb-1">
      <label class="inline-flex cursor-pointer items-center">
        <input type="checkbox" value="recommended" class="peer sr-only" data-course-filter-checkbox="coursework" />
        <span class="rounded-full border border-black/10 bg-white/70 px-3 py-1 text-sm font-medium text-(--active-muted) shadow-sm transition peer-checked:bg-(--active-hue) peer-checked:text-white">
          👍 Recommended
        </span>
      </label>
      <label class="inline-flex cursor-pointer items-center">
        <input type="checkbox" value="not-recommended" class="peer sr-only" data-course-filter-checkbox="coursework" />
        <span class="rounded-full border border-black/10 bg-white/70 px-3 py-1 text-sm font-medium text-(--active-muted) shadow-sm transition peer-checked:bg-(--active-hue) peer-checked:text-white">
          👎 Not recommended
        </span>
      </label>
    </div>
  </details>
</section>

<section
  class="mx-4 md:mx-0 mt-12 mb-8 flex flex-wrap items-center gap-x-8 gap-y-4"
>
  <nav
    class="flex justify-center items-center gap-1 w-fit font-sans shadow-border rounded-full"
    aria-label="Site sections"
  >
    {
      tabs.map((tab, index) => (
        <button
          type="button"
          class:list={[
            "px-4 py-2 rounded-full inline-flex items-center gap-2 transition-colors weight-medium",
            index === 0
              ? "bg-white/65 shadow-card"
              : "hover:bg-white/50 text-(--active-muted)",
          ]}
          aria-selected={index === 0}
          aria-controls={`${tab.id}-panel`}
          data-tab-button={tab.id}
        >
          {tab.label}
        </button>
      ))
    }
  </nav>
</section>

<section aria-label="Site content">
  <div id="projects-panel" data-tab-panel="projects">
    <section aria-label="Projects" class="grid gap-4 lg:gap-8 md:grid-cols-2">
      {allProjects.map((project) => <Project project={project} />)}
    </section>
  </div>

  <div id="blog-panel" data-tab-panel="blog" hidden>
    {allBlogPosts.length ? (
      <section aria-label="Blog posts" class="space-y-4">
        {allBlogPosts.map((post) => <BlogCard post={post} />)}
      </section>
    ) : (
      <div class={emptyStateClasses}>
        Blog content will live here next.
      </div>
    )}
  </div>

  <div id="coursework-panel" data-tab-panel="coursework" hidden>
    {courseworkGroups.size ? (
      <section aria-label="Coursework" class="space-y-10">
        {Array.from(courseworkGroups.entries()).map(([quarter, courses]) => (
          <section data-course-group class="space-y-4">
            <h2 class="text-2xl font-triple weight-medium text-(--active-muted)">
              {quarter}
            </h2>
            <div class="space-y-1">
              {courses.map((course) => (
                <CourseworkListItem course={course} />
              ))}
            </div>
          </section>
        ))}
      </section>
    ) : (
      <div class={emptyStateClasses}>
        Coursework content will live here next.
      </div>
    )}
  </div>
</section>

<script is:inline>
  const tabButtons = Array.from(document.querySelectorAll("[data-tab-button]"))
  const tabPanels = Array.from(document.querySelectorAll("[data-tab-panel]"))
  const filterPanels = Array.from(document.querySelectorAll("[data-filter-panel]"))
  const activeTabStorageKey = "home-tab"
  const activeFilterStorageKey = "home-filters"

  function setActiveTab(tabId, persist = true) {
    tabButtons.forEach((button) => {
      const isActive = button.dataset.tabButton === tabId
      button.setAttribute("aria-selected", String(isActive))
      button.classList.toggle("bg-white/65", isActive)
      button.classList.toggle("shadow-card", isActive)
      button.classList.toggle("hover:bg-white/50", !isActive)
      button.classList.toggle("text-(--active-muted)", !isActive)
    })

    tabPanels.forEach((panel) => {
      panel.hidden = panel.dataset.tabPanel !== tabId
    })

    if (persist) {
      sessionStorage.setItem(activeTabStorageKey, tabId)
    }

    filterPanels.forEach((panel) => {
      panel.hidden = panel.dataset.filterPanel !== tabId
    })

    applyFilters(tabId, false)
  }

  function getCurrentFilters(tabId) {
    const savedFilters = sessionStorage.getItem(activeFilterStorageKey)
    const parsedFilters = savedFilters ? JSON.parse(savedFilters) : {}
    return parsedFilters[tabId] ?? {}
  }

  function saveCurrentFilters(tabId, state) {
    const savedFilters = sessionStorage.getItem(activeFilterStorageKey)
    const parsedFilters = savedFilters ? JSON.parse(savedFilters) : {}
    parsedFilters[tabId] = state
    sessionStorage.setItem(activeFilterStorageKey, JSON.stringify(parsedFilters))
  }

  function applyFilters(tabId, persist = true) {
    const panel = document.querySelector(`[data-filter-panel="${tabId}"]`)
    if (!panel) return

    if (tabId === "projects" || tabId === "blog") {
      const searchInput = panel.querySelector(`[data-tag-search="${tabId}"]`)
      const tagCheckboxInputs = Array.from(
        panel.querySelectorAll(`[data-tag-checkbox="${tabId}"]`),
      )
      const tagOptions = Array.from(panel.querySelectorAll("[data-tag-option]"))

      const selectedTags = tagCheckboxInputs
        .filter((checkbox) => checkbox.checked)
        .map((checkbox) => checkbox.value)

      const searchQuery = searchInput instanceof HTMLInputElement ? searchInput.value.trim().toLowerCase() : ""

      tagOptions.forEach((option) => {
        const tagName = option.dataset.tagName?.toLowerCase() ?? ""
        option.hidden = searchQuery.length > 0 && !tagName.includes(searchQuery)
      })

      const items = Array.from(
        document.querySelectorAll(`[data-tab-panel="${tabId}"] [data-filter-item="true"]`),
      )

      items.forEach((item) => {
        const itemTags = (item.dataset.tags ?? "")
          .split(",")
          .map((tag) => tag.trim())
          .filter(Boolean)
        const matches =
          selectedTags.length === 0 || itemTags.some((tag) => selectedTags.includes(tag))

        item.hidden = !matches
      })

      if (persist) {
        saveCurrentFilters(tabId, { tags: selectedTags, query: searchQuery })
      }
    }

    if (tabId === "coursework") {
      const selectedModes = Array.from(
        panel.querySelectorAll(`[data-course-filter-checkbox="coursework"]`),
      )
        .filter((checkbox) => checkbox.checked)
        .map((checkbox) => checkbox.value)

      const items = Array.from(
        document.querySelectorAll(`[data-tab-panel="coursework"] [data-filter-item="true"]`),
      )

      items.forEach((item) => {
        const mode = item.dataset.recommended === "true" ? "recommended" : "not-recommended"
        const matches = selectedModes.length === 0 || selectedModes.includes(mode)
        item.hidden = !matches
      })

      const groups = Array.from(panel.querySelectorAll("[data-course-group]"))
      groups.forEach((group) => {
        const visibleItems = Array.from(group.querySelectorAll("[data-filter-item='true']")).some(
          (item) => !item.hidden,
        )
        group.hidden = !visibleItems
      })

      if (persist) {
        saveCurrentFilters(tabId, { modes: selectedModes })
      }
    }
  }

  filterPanels.forEach((panel) => {
    const panelId = panel.dataset.filterPanel
    const state = getCurrentFilters(panelId)

    if (panelId === "projects" || panelId === "blog") {
      const searchInput = panel.querySelector(`[data-tag-search="${panelId}"]`)
      const tagCheckboxInputs = Array.from(
        panel.querySelectorAll(`[data-tag-checkbox="${panelId}"]`),
      )

      if (searchInput instanceof HTMLInputElement && typeof state.query === "string") {
        searchInput.value = state.query
      }

      tagCheckboxInputs.forEach((checkbox) => {
        checkbox.checked = Array.isArray(state.tags) && state.tags.includes(checkbox.value)
        checkbox.addEventListener("change", () => applyFilters(panelId))
      })

      if (searchInput instanceof HTMLInputElement) {
        searchInput.addEventListener("input", () => applyFilters(panelId))
      }
    }

    if (panelId === "coursework") {
      const modeCheckboxes = Array.from(
        panel.querySelectorAll(`[data-course-filter-checkbox="coursework"]`),
      )

      modeCheckboxes.forEach((checkbox) => {
        checkbox.checked = Array.isArray(state.modes) && state.modes.includes(checkbox.value)
        checkbox.addEventListener("change", () => applyFilters(panelId))
      })
    }

    panel.hidden = panelId !== "projects"
  })

  const savedTab = sessionStorage.getItem(activeTabStorageKey)
  if (savedTab && tabButtons.some((button) => button.dataset.tabButton === savedTab)) {
    setActiveTab(savedTab, false)
  } else {
    setActiveTab("projects", false)
  }

  tabButtons.forEach((button) => {
    button.addEventListener("click", () => {
      setActiveTab(button.dataset.tabButton)
    })
  })
</script>