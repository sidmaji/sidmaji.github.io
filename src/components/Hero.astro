      </p>
    </div> -->
  </details>
</header>

<section
  class="mx-4 md:mx-0 mt-12 mb-8 flex flex-wrap items-center gap-x-8 gap-y-4"
>
  <nav
    class="flex justify-center items-center gap-1 w-fit font-sans shadow-border rounded-full"
    aria-label="Site sections"
  >
    {
      tabs.map((tab, index) => (
        <button
          type="button"
          class:list={[
            "px-4 py-2 rounded-full inline-flex items-center gap-2 transition-colors weight-book",
            index === 0
              ? "bg-white/65 shadow-card"
              : "hover:bg-white/50 text-(--active-muted)",
          ]}
          aria-selected={index === 0}
          aria-controls={`${tab.id}-panel`}
          data-tab-button={tab.id}
        >
          {tab.label}
        </button>
      ))
    }
  </nav>
</section>

<section aria-label="Site content">
  <div id="projects-panel" data-tab-panel="projects">
    <section aria-label="Projects" class="grid gap-4 lg:gap-8 md:grid-cols-2">
      {allProjects.map((project) => <Project project={project} />)}
    </section>
  </div>

  <div id="blog-panel" data-tab-panel="blog" hidden>
    <div class={emptyStateClasses}>
      Blog content will live here next.
    </div>
  </div>

  <div id="coursework-panel" data-tab-panel="coursework" hidden>
    <div class={emptyStateClasses}>
      Coursework content will live here next.
    </div>
  </div>
</section>

<script is:inline>
  const tabButtons = Array.from(document.querySelectorAll("[data-tab-button]"))
  const tabPanels = Array.from(document.querySelectorAll("[data-tab-panel]"))
  const activeTabStorageKey = "home-tab"

  function setActiveTab(tabId, persist = true) {
    tabButtons.forEach((button) => {
      const isActive = button.dataset.tabButton === tabId
      button.setAttribute("aria-selected", String(isActive))
      button.classList.toggle("bg-white/65", isActive)
      button.classList.toggle("shadow-card", isActive)
      button.classList.toggle("hover:bg-white/50", !isActive)
      button.classList.toggle("text-(--active-muted)", !isActive)
    })

    tabPanels.forEach((panel) => {
      panel.hidden = panel.dataset.tabPanel !== tabId
    })

    if (persist) {
      sessionStorage.setItem(activeTabStorageKey, tabId)
    }
  }

  const savedTab = sessionStorage.getItem(activeTabStorageKey)
  if (savedTab && tabButtons.some((button) => button.dataset.tabButton === savedTab)) {
    setActiveTab(savedTab, false)
  }

  tabButtons.forEach((button) => {
    button.addEventListener("click", () => {
      setActiveTab(button.dataset.tabButton)
    })
  })
</script>