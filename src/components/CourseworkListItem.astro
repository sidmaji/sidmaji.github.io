---
import type { CollectionEntry } from "astro:content"

interface Props {
  course: CollectionEntry<"coursework">
}

const { course } = Astro.props
---

<a
  href={`/coursework/${course.id}`}
  data-filter-item="true"
  data-recommended={String(course.data.recommended)}
  class="group flex items-start gap-3 rounded-2xl px-2 py-2 transition-colors hover:bg-white/35"
>
  {
    course.data.recommended ? (
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="feather feather-thumbs-up mt-0.5 shrink-0 text-(--active-hue)"
        aria-hidden="true"
      >
        <path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3" />
      </svg>
    ) : (
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="feather feather-thumbs-down mt-0.5 shrink-0 text-(--active-hue)"
        aria-hidden="true"
      >
        <path d="M10 15v4a3 3 0 0 0 3 3l4-9V2H5.72a2 2 0 0 0-2 1.7l-1.38 9a2 2 0 0 0 2 2.3zm7-13h2.67A2.31 2.31 0 0 1 22 4v7a2.31 2.31 0 0 1-2.33 2H17" />
      </svg>
    )
  }
  <span class="min-w-0">
    <span class="block text-lg font-medium leading-snug text-(--active-hue)">
      {course.data.name}
    </span>
  </span>
</a>
