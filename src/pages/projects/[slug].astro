---
import { Image } from "astro:assets"
import { getCollection, render } from "astro:content"
import Layout from "~/layouts/Layout.astro"

export async function getStaticPaths() {
  const projects = await getCollection("projects")

  return projects.map((project) => ({
    params: { slug: project.id },
  }))
}

const { slug } = Astro.params
const projects = await getCollection("projects")
const project = projects.find((entry) => entry.id === slug)

if (!project) {
  throw new Error(`Project not found: ${slug}`)
}

const { Content } = await render(project)
---

<Layout
  title={project.data.name}
  desc={project.data.desc ?? "Project page"}
  img={project.data.cover.src ?? "https://lachlanjc.com/opengraph-image.jpg"}
  className="py-4 flex flex-col gap-12 md:gap-24"
>
  <article class="container mx-auto max-w-4xl px-4 prose prose-h1:text-6xl prose-a:no-underline prose-a:weight-medium prose-img:rounded-lg prose-img:my-8 prose-img:w-full">
    <a
      href="/"
      class="text-xl font-triple block md:-mt-12 py-4 font-mono-slabs transition-transform hover:-translate-x-6"
    >
      &larr; @siddhant-maji
    </a>
    <p class="font-sans text-sm uppercase tracking-wide text-(--active-muted) mb-2">
      {project.data.year}
    </p>
    <h1 class="mb-4">{project.data.name}</h1>
    {project.data.cover ? (
      <Image
        src={project.data.cover}
        alt={project.data.coverAlt}
        class="w-full"
        loading="eager"
      />
    ) : null}
    <p class="text-xl text-balance">{project.data.desc}</p>
    <Content />
  </article>
</Layout>